# oodle — Environment Variables
# Copy this file to .env.local and fill in your values.
# Get Supabase values from: supabase.com → your project → Settings → API
# Get Stripe values from: dashboard.stripe.com → Developers → API keys

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (Step 6 — add when ready for payments) ────────────────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...          # server-side only (Edge Function)
# STRIPE_WEBHOOK_SECRET=whsec_...        # Edge Function webhook verification
